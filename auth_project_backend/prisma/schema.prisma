generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum role {
  ADMIN
  USER
}
model User {
  id Int @default(autoincrement()) @id
  email String @unique
  password String
  name String
  tasks Task[]
  refreshToken String?
  role role @default(USER) 
}

model Task {
  id Int @default(autoincrement()) @id
  task_name String
  completed Boolean @default(false)
  userId Int
  user User @relation(fields: [userId], references: [id])
}