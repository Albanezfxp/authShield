generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum role {
  ADMIN
  USER
}

enum situation {
  TO_DO
  IN_PROGRESS
  DONE
}

model User {
  id Int @default(autoincrement()) @id
  email String @unique
  password String
  name String
  tasks Task[]
  refreshToken String?
  role role @default(USER) 
}

model Task {
  id Int @default(autoincrement()) @id
  task_name String
  description String
  situation situation @default(TO_DO)
  userId Int
  user User @relation(fields: [userId], references: [id])
}